        <mxCell id="p_decision" value="試合 or&#xa;練習？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Noto Sans JP;fontSize=18;fontColor=#000000;" vertex="1" parent="lane1">
          <mxGeometry x="470" y="55" width="130" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p_match" value="（試合記録&#xa;フローへ）" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#f8f8f8;strokeColor=#94A3B8;fontFamily=Noto Sans JP;fontSize=18;fontColor=#94A3B8;dashed=1;" vertex="1" parent="lane1">
          <mxGeometry x="720" y="70" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_input" value="タイプ・時間&#xa;メモ入力" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#6c8ebf;fontFamily=Noto Sans JP;fontSize=18;fontColor=#000000;" vertex="1" parent="lane1">
          <mxGeometry x="1020" y="70" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- アプリレーン要素 -->
        <mxCell id="p_type_select" value="記録タイプ&#xa;選択画面" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#82b366;fontFamily=Noto Sans JP;fontSize=18;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="230" y="65" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_form" value="練習フォーム&#xa;表示" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#82b366;fontFamily=Noto Sans JP;fontSize=18;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="720" y="65" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_save" value="記録保存" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ffffff;strokeColor=#82b366;fontFamily=Noto Sans JP;fontSize=18;fontColor=#000000;" vertex="1" parent="lane2">
          <mxGeometry x="1020" y="65" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_done" value="タイムライン&#xa;に表示" style="ellipse;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;fontFamily=Noto Sans JP;fontSize=18;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="lane2">
          <mxGeometry x="1310" y="60" width="170" height="90" as="geometry" />
