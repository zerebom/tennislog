        <!-- ユーザーレーン要素 -->
        <mxCell id="p_start" value="＋ボタン&#xa;タップ" style="ellipse;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;fontFamily=Noto Sans JP;fontSize=18;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="lane1">
          <mxGeometry x="40" y="70" width="140" height="80" as="geometry" />
