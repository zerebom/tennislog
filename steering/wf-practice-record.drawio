        <mxCell id="e3" value="練習" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#F59E0B;strokeWidth=2;fontFamily=Noto Sans JP;fontSize=16;fontColor=#F59E0B;fontStyle=1;" edge="1" parent="1" source="p_decision" target="p_form">
