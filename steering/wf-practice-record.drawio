        <mxCell id="lane2" value="アプリ" style="swimlane;html=1;startSize=40;horizontal=1;containerType=tree;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Noto Sans JP;fontSize=18;fontColor=#000000;" vertex="1" parent="1">
