<mxfile host="Electron">
  <diagram name="WF-3 練習記録" id="wf3">
    <mxGraphModel dx="1800" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1800" pageHeight="650" background="#FFFFFF" defaultFontFamily="Noto Sans JP">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

