        <mxCell id="lane1" value="ユーザー" style="swimlane;html=1;startSize=40;horizontal=1;containerType=tree;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Noto Sans JP;fontSize=18;fontColor=#000000;" vertex="1" parent="1">
